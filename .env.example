# ══════════════════════════════════════════════════════════════════════════════
# Zerocast — Environment Variables Reference
# Copy to .env.local for local development. Never commit .env.local.
# Production values are set in the Vercel dashboard or via `vercel env add`.
# ══════════════════════════════════════════════════════════════════════════════

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Secret used to sign session tokens and CSRF tokens.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of the app. Used by NextAuth to build callback URLs.
# Local: http://localhost:3000
# Production: https://zerocast.vercel.app (or your custom domain)
NEXTAUTH_URL=http://localhost:3000

# NODE_ENV is set automatically by Next.js:
#   next dev   → development
#   next build → production
# Do NOT set it manually here — Next.js will warn and it can cause conflicts.

# ── Google OAuth ───────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
#
# Required Authorized redirect URIs (add all that apply):
#   http://localhost:3000/api/auth/callback/google   (local dev)
#   https://zerocast.vercel.app/api/auth/callback/google  (production)
#
# Required Authorized JavaScript origins:
#   http://localhost:3000
#   https://zerocast.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Twitch OAuth (optional — only needed if you want Twitch token refresh) ────
# dev.twitch.tv → Console → Applications → Your App
# Required if you store Twitch OAuth tokens in PlatformConnection.
# For read-only chat via tmi.js (channel name only), these are NOT needed.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Resend (email magic links) ─────────────────────────────────────────────────
# resend.com → API Keys
# When absent, the email login option is hidden and NextAuth won't crash.
RESEND_API_KEY=

# The "From" address for magic link emails. Must be a verified sender in Resend.
#
# Without a verified domain:
#   Use onboarding@resend.dev (Resend's own verified test sender).
#   Free plan only delivers to email addresses registered in your Resend account.
#
# With a verified domain (resend.com/domains):
#   Use noreply@yourdomain.com — delivers to any recipient.
#
# To verify a domain: add DNS records (MX, SPF, DKIM) from resend.com/domains.
RESEND_FROM=onboarding@resend.dev

# ── Neon Postgres ──────────────────────────────────────────────────────────────
# neon.tech → your project → Connection Details
# DATABASE_URL uses the connection pooler (required for serverless/edge).
# DIRECT_URL bypasses the pooler (required for Prisma migrations).
DATABASE_URL=
DIRECT_URL=

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── LiveKit Cloud ──────────────────────────────────────────────────────────────
# cloud.livekit.io → your project → Settings → Keys
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# wss:// URL from your LiveKit project settings
NEXT_PUBLIC_LIVEKIT_URL=

# ── Gemini AI (optional — powers the AI chat assistant) ───────────────────────
# aistudio.google.com → Get API key (free tier: 15 RPM, 1500 RPD, no billing required)
# When absent, the AI Chat Assistant feature is disabled server-side.
GEMINI_API_KEY=

# ── Cloudflare R2 (recording storage) ─────────────────────────────────────────
# S3-compatible object storage with free egress. Required for recording feature.
# Setup:
#   1. dash.cloudflare.com → R2 → Create bucket (e.g. "zerocast-recordings")
#   2. R2 → Manage API Tokens → Create token with Admin Read & Write on the bucket
#   3. Copy Access Key ID + Secret + S3 Endpoint
#   4. Account ID lives on the Cloudflare dashboard right sidebar
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
# Optional: custom domain for direct downloads. If unset, recordings are served
# via presigned URLs that expire after 24h.
R2_PUBLIC_URL=

# ── PostHog Query API ──────────────────────────────────────────────────────────
# Server-side; required for /admin/analytics, /admin/funnel, /admin/retention.
# Capture (client SDK) uses NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN — these are extra.
#
# POSTHOG_PROJECT_ID:
#   Numeric project id from the PostHog dashboard URL:
#   https://us.posthog.com/project/<id>/...
POSTHOG_PROJECT_ID=
# POSTHOG_PERSONAL_API_KEY:
#   Create at us.posthog.com → Settings → Personal API Keys.
#   Required scope: "Query API: Read". Treat as a secret — never expose to client.
POSTHOG_PERSONAL_API_KEY=

# ── Sentry (server-side error tracking; PostHog handles client) ───────────────
# Project setup: sentry.io → New Project → Next.js. Free tier: 5K errors/mo.
SENTRY_DSN=
# The next 3 enable source-map upload during build. Optional for local; required
# for stack traces to be readable in production.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Launch mode ─────────────────────────────────────────────────────
# Flips marketing CTAs from "Request Access → BetaModal" (private beta)
# to "Sign up free → /login" (public). BetaModal short-circuits any
# remaining ?beta=true links to /login so existing call sites keep
# working. See src/lib/launch.ts. Toggle is read at build time —
# redeploy after flipping.
NEXT_PUBLIC_LAUNCH_OPEN=false

# ── Slack (realtime ops alerts; each webhook = one channel) ──────────────────
# Create per-channel incoming webhooks at
# https://api.slack.com/apps → Your App → Incoming Webhooks → Add New.
# Any var unset → that channel goes dark (other channels keep working).
SLACK_WEBHOOK_BETA_SIGNUPS=
SLACK_WEBHOOK_STREAMS=
SLACK_WEBHOOK_ALERTS=
SLACK_WEBHOOK_DIGEST=
