# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Primary variables (NextAuth v5 / @auth/core expect these names)
AUTH_SECRET=                          # generate: openssl rand -base64 32
AUTH_URL=http://localhost:3000        # production: https://zerocast.vercel.app
AUTH_TRUST_HOST=true

# Legacy aliases (kept for backwards compat — same values as AUTH_* above)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google
#   https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend (email magic link) ─────────────────────────────────────────────────
# resend.com — optional; email login is disabled when this is absent
RESEND_API_KEY=
RESEND_FROM=                          # e.g. noreply@yourdomain.com (must be verified in Resend)

# ─── Neon Postgres ─────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── LiveKit Cloud ─────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=
