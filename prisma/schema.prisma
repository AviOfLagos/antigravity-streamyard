generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoomStatus {
  LOBBY
  LIVE
  ENDED
}

enum PlatformType {
  YOUTUBE
  TWITCH
  KICK
  TIKTOK
}

enum StreamStatus {
  STARTING
  LIVE
  STOPPING
  ENDED
  FAILED
}

enum ParticipantRole {
  HOST
  GUEST
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?
  image               String?
  accounts            Account[]
  sessions            Session[]
  platformConnections PlatformConnection[]
  rooms               Room[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PlatformConnection {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     PlatformType
  channelId    String
  channelName  String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  streamKey    String?      // RTMP stream key (encrypted at rest by Neon)
  ingestUrl    String?      // Custom RTMP ingest URL (mainly for TikTok)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, platform])
}

model Room {
  id                String         @id @default(cuid())
  code              String         @unique
  title             String?
  hostId            String
  host              User           @relation(fields: [hostId], references: [id])
  status            RoomStatus     @default(LOBBY)
  autoAdmit         Boolean        @default(false)
  selectedPlatforms PlatformType[]
  createdAt         DateTime       @default(now())
  endedAt           DateTime?
  participants      Participant[]
  streamSessions    StreamSession[]
  guestLeads        GuestLead[]
}

model Participant {
  id       String          @id @default(cuid())
  roomId   String
  room     Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name     String
  identity String          // LiveKit identity string (e.g., "host-xxx" or "guest-xxx")
  role     ParticipantRole
  joinedAt DateTime        @default(now())
  leftAt   DateTime?

  @@index([roomId])
}

model GuestLead {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name      String
  email     String
  joinedAt  DateTime @default(now())

  @@index([roomId])
  @@index([email])
}

model StreamSession {
  id             String         @id @default(cuid())
  roomId         String
  room           Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  egressId       String?        @unique   // LiveKit egress ID
  platforms      PlatformType[] // Which platforms are being streamed to
  status         StreamStatus   @default(STARTING)
  startedAt      DateTime       @default(now())
  endedAt        DateTime?
  error          String?        // Error message if FAILED

  @@index([roomId])
}
